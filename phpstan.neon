parameters:
    level: 8
    paths:
        - config/
        - src/
    ignoreErrors:
        -
            identifier: missingType.iterableValue
        -
            message: '#Call to method arrayNode\(\) on an unknown class Symfony\\Component\\Config\\Definition\\Builder\\NodeBuilder<.+>\.#'
            path: src/SRFPolisBundle.php
            count: 1
